# Optional cloud OpenAI activation for Care Nova AI.
# Keep this disabled until a real API key is configured.

CARE_NOVA_ONLINE_MODE=true
CARE_NOVA_PAID_MODELS_ENABLED=false
CARE_NOVA_CLOUD_MODELS_ENABLED=false
CARE_NOVA_OPENAI_ENABLED=false
CARE_NOVA_SPECIALIST_LLM_CLOUD_ENABLED=false

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_BASE_URL=

# Keep the final-response cloud rewrite off by default.
# Turn this on only if you want every final response to get a cloud second pass.
CARE_NOVA_TEMP_CLOUD_RESPONSE_ENABLED=false
CARE_NOVA_TEMP_CLOUD_PROVIDER=openai
CARE_NOVA_TEMP_CLOUD_API_URL=https://api.openai.com/v1/chat/completions
CARE_NOVA_TEMP_CLOUD_MODEL=gpt-5.4
CARE_NOVA_TEMP_CLOUD_API_KEY=
CARE_NOVA_TEMP_CLOUD_API_KEY_HEADER=
CARE_NOVA_TEMP_CLOUD_API_AUTH_SCHEME=Bearer
CARE_NOVA_TEMP_CLOUD_TIMEOUT_MS=12000
